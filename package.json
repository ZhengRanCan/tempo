{
  "name": "tempo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:mp-weixin": "node scripts/uni-run.mjs -p mp-weixin",
    "build:mp-weixin": "node scripts/uni-run.mjs build -p mp-weixin",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "verify:static": "npm run lint && npm run typecheck",
    "verify:feature": "npm run test",
